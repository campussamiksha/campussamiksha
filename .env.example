# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campussamiksha?schema=public"

# App
NODE_ENV="development"
NEXT_PUBLIC_SITE_NAME="CampusSamiksha"

# Auth — set a long random string in production (e.g. `openssl rand -base64 48`)
SESSION_SECRET="dev-insecure-secret-change-me"

# Seed: initial moderator/admin account (created by `npm run db:seed`)
ADMIN_EMAIL="admin@campussamiksha.local"
ADMIN_PASSWORD="ChangeMe123!"

# Public base URL — used to build absolute links in emails
APP_URL="http://localhost:3000"

# Email delivery. 'console' (default) logs emails to the server console.
# Set to 'smtp' and fill the SMTP_* vars for real delivery (e.g. a provider
# like Amazon SES, Postmark, SendGrid, or any SMTP relay).
MAIL_TRANSPORT="console"
MAIL_FROM="CampusSamiksha <no-reply@campussamiksha.in>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
